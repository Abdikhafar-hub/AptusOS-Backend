  GENERAL_MANAGER
  DEPARTMENT_HEAD
  HR_MANAGER
  FINANCE_ACCOUNTS_MANAGER
  FINANCE_MANAGER
  ACCOUNTS_OFFICER
  SALES_COMPLIANCE_OFFICER
  OPERATIONS_PROCUREMENT_OFFICER
  EMPLOYEE
  CUSTOM
}

