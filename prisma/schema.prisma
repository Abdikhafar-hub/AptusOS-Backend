model Role {
  id          String           @id @default(cuid())
  name        RoleName
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  requisitionApprovalSteps RequisitionApprovalStep[] @relation("RequisitionStepApproverRole")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  @@unique([name, deletedAt])
  @@index([name])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())
  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model User {
  id                     String                     @id @default(cuid())
  firstName              String
  lastName               String
  fullName               String
  email                  String                     @unique
  phone                  String?
  alternatePhone         String?
  gender                 Gender?
  dateOfBirth            DateTime?
  nationalId             String?
  passport               String?
  kraPin                 String?
  address                String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  jobTitle               String?
  employmentType         EmploymentType            @default(FULL_TIME)
  employmentStatus       EmploymentStatus          @default(ACTIVE)
  joinDate               DateTime?
  departmentId           String?
  managerId              String?
  roleId                 String
  passwordHash           String?
  mustChangePassword     Boolean                    @default(true)
  profilePhotoUrl        String?
  notes                  String?
  isActive               Boolean                    @default(true)
  lastLoginAt            DateTime?
  department             Department?                @relation("UserDepartment", fields: [departmentId], references: [id])
  manager                User?                      @relation("Manager", fields: [managerId], references: [id])
  directReports          User[]                     @relation("Manager")
  role                   Role                       @relation(fields: [roleId], references: [id])
  headedDepartments      Department[]               @relation("DepartmentHead")
  departmentMemberships  DepartmentMember[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  documentsUploaded      Document[]                 @relation("UploadedDocuments")
  documentsApproved      Document[]                 @relation("ApprovedDocuments")
  requestedApprovals     ApprovalRequest[]          @relation("RequestedApprovals")
  currentApprovals       ApprovalRequest[]          @relation("CurrentApprover")
  assignedTasks          Task[]                     @relation("AssignedTasks")
  createdTasks           Task[]                     @relation("CreatedTasks")
  comments               Comment[]
  notifications          Notification[]
  conversations          ConversationParticipant[]
  messages               Message[]
  channelMembers         ChannelMember[]
  channelMessages        ChannelMessage[]
  announcements          Announcement[]
  announcementReads      AnnouncementRead[]
  leaveRequests          LeaveRequest[]
  leaveBalances          LeaveBalance[]
  attendanceRecords      AttendanceRecord[]
  onboardingChecklists   OnboardingChecklist[]
  hrActions              HRAction[]                 @relation("EmployeeHRActions")
  separations            Separation[]
  remunerations          Remuneration[]
  payslips               Payslip[]                  @relation("EmployeePayslips")
  generatedPayslips      Payslip[]                  @relation("GeneratedPayslips")
  employeeCompensations  EmployeeCompensation[]     @relation("EmployeeCompensations")
  compensationProfilesCreated EmployeeCompensation[] @relation("CompensationCreators")
  allowances             Allowance[]                @relation("EmployeeAllowances")
  deductions             Deduction[]                @relation("EmployeeDeductions")
  allowancesCreated      Allowance[]                @relation("AllowanceCreators")
  deductionsCreated      Deduction[]                @relation("DeductionCreators")
  payrollCyclesCreated   PayrollCycle[]             @relation("PayrollCycleCreatedBy")
  payrollCyclesApproved  PayrollCycle[]             @relation("PayrollCycleApprovedBy")
  payrollRecords         PayrollRecord[]            @relation("PayrollRecordEmployee")
  payrollAuditLogs       PayrollAuditLog[]          @relation("PayrollAuditPerformer")
  payrollRulesCreated    PayrollStatutoryRule[]     @relation("PayrollRuleCreator")
  financeRequests        FinanceRequest[]
  customerOnboardings    CustomerOnboarding[]
  ownedCustomerAccounts  CustomerOnboarding[]        @relation("CustomerAccountOwner")
  assignedTerritories    SalesTerritory[]            @relation("TerritoryOfficer")
  visitRoutes            VisitRoute[]                @relation("VisitRouteOfficer")
  customerAccountNotes   CustomerAccountNote[]       @relation("CustomerAccountNoteAuthor")
  salesOpportunitiesOwned SalesOpportunity[]         @relation("SalesOpportunityOwner")
  productFeedbackSubmitted ProductFeedback[]         @relation("ProductFeedbackSubmitter")
  customerIssuesReported CustomerIssue[]             @relation("CustomerIssueReporter")
  customerIssuesAssigned CustomerIssue[]             @relation("CustomerIssueAssignee")
  discountRequestsRequested DiscountRequest[]        @relation("DiscountRequestRequester")
  salesReports           SalesReport[]
  clientVisitNotes       ClientVisitNote[]
  complaintEscalations   ComplaintEscalation[]
  complianceItems        ComplianceItem[]
  riskRegisters          RiskRegister[]
  incidentReports        IncidentReport[]
  policyAcknowledgements PolicyAcknowledgement[]
  requisitions           Requisition[]
  requisitionAttachmentsUploaded RequisitionAttachment[] @relation("RequisitionAttachmentUploader")
  requisitionApprovalStepsAssigned RequisitionApprovalStep[] @relation("RequisitionStepApproverUser")
  requisitionAuditLogs   RequisitionAuditLog[] @relation("RequisitionAuditActor")
  logisticsTasksCreated  LogisticsTask[] @relation("LogisticsTaskCreator")
  logisticsTasksPrimaryAssigned LogisticsTask[] @relation("LogisticsTaskPrimaryAssignee")
  logisticsTasksSupervised LogisticsTask[] @relation("LogisticsTaskSupervisor")
  logisticsTeamMemberships LogisticsTaskTeamMember[]
  logisticsTaskDocumentsUploaded LogisticsTaskDocument[] @relation("LogisticsTaskDocumentUploader")
  logisticsTaskAuditLogs LogisticsTaskAuditLog[] @relation("LogisticsTaskAuditActor")
  trainings              Training[]                 @relation("TrainingCreator")
  trainingParticipants   TrainingParticipant[]
  performanceReviews     PerformanceReview[]        @relation("EmployeeReviews")
  reviewsGiven           PerformanceReview[]        @relation("ReviewerReviews")
  auditLogs              AuditLog[]
  escalationsCreated     EscalationLog[]            @relation("EscalationCreator")
  escalationsResolved    EscalationLog[]            @relation("EscalationResolver")
  ownedContracts         Contract[]                 @relation("ContractOwner")
  createdDelegations     Delegation[]               @relation("DelegationCreator")
  delegatedAssignments   Delegation[]               @relation("DelegationAssignee")
  resolvedDelegations    Delegation[]               @relation("DelegationResolver")
  approverDelegations    Delegation[]               @relation("DelegationApprover")
  approvedDelegations    Delegation[]               @relation("DelegationApprovedBy")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  deletedAt              DateTime?
  @@index([roleId])
  @@index([departmentId])
  @@index([managerId])
  @@index([employmentStatus])
}

model Department {
  id             String             @id @default(cuid())
  name           String             @unique
  slug           String             @unique
  description    String?
  headId         String?
  status         DepartmentStatus   @default(ACTIVE)
  head           User?              @relation("DepartmentHead", fields: [headId], references: [id])
  staff          User[]             @relation("UserDepartment")
  members        DepartmentMember[]
  documents      Document[]
  channels       Channel[]
  announcements  Announcement[]
  tasks          Task[]
  leavePolicies  LeavePolicy[]
  financeRequests FinanceRequest[]
  budgets        Budget[]
  allowances     Allowance[]
  deductions     Deduction[]
  contracts      Contract[]
  restrictedDelegations Delegation[] @relation("DelegationRestrictedDepartment")
  requisitions   Requisition[]
  logisticsTasks LogisticsTask[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  @@index([headId])
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  userId       String
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@unique([departmentId, userId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@index([userId])
}

model Document {
  id                 String            @id @default(cuid())
  title              String
  description        String?
  category           DocumentCategory
  documentType       String?
  fileUrl            String
  cloudinaryPublicId String?
  fileName           String
  mimeType           String
  fileSize           Int
  ownerType          DocumentOwnerType
  ownerId            String?
  uploadedById       String
  departmentId       String?
  visibility         Visibility        @default(PRIVATE)
  status             DocumentStatus    @default(DRAFT)
  version            Int               @default(1)
  parentDocumentId   String?
  expiryDate         DateTime?
  reminderDate       DateTime?
  approvedById       String?
  approvedAt         DateTime?
  rejectionReason    String?
  uploadedBy         User              @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  approvedBy         User?             @relation("ApprovedDocuments", fields: [approvedById], references: [id])
  department         Department?       @relation(fields: [departmentId], references: [id])
  parentDocument     Document?         @relation("DocumentVersions", fields: [parentDocumentId], references: [id])
  versions           Document[]        @relation("DocumentVersions")
  documentVersions   DocumentVersion[]
  comments           Comment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  @@index([category])
  @@index([ownerType, ownerId])
  @@index([departmentId])
  @@index([status])
  @@index([expiryDate])
}

model DocumentVersion {
  id                 String   @id @default(cuid())
  documentId         String
  version            Int
  fileUrl            String
  cloudinaryPublicId String?
  fileName           String
  mimeType           String
  fileSize           Int
  uploadedById       String
