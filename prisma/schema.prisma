  delegateUser     User             @relation("DelegationAssignee", fields: [delegateUserId], references: [id])
  restrictedDepartment Department?  @relation("DelegationRestrictedDepartment", fields: [restrictedDepartmentId], references: [id])
  approver         User?            @relation("DelegationApprover", fields: [approverId], references: [id])
  approvedBy       User?            @relation("DelegationApprovedBy", fields: [approvedById], references: [id])
  resolvedBy       User?            @relation("DelegationResolver", fields: [resolvedById], references: [id])
