model Requisition {
  id                String         @id @default(cuid())
  requestedById      String
  departmentId       String?
  title              String
  description        String?
  requestCategory    RequisitionCategory      @default(GOODS)
  requestType        RequisitionRequestType   @default(NEW_PURCHASE)
  businessJustification String?
  requiredByDate     DateTime?
  urgencyReason      String?
  emergencyJustification String?
  estimatedAmount    Decimal?
  subtotal           Decimal                  @default(0)
  taxApplicable      Boolean                  @default(false)
  taxRate            Decimal?
  taxAmount          Decimal                  @default(0)
  grandTotal         Decimal                  @default(0)
  currency           String                   @default("KES")
  budgetLine         String?
  costCenter         String?
  fundingSource      RequisitionFundingSource @default(DEPARTMENT_BUDGET)
  budgetAvailableAmount Decimal?
  budgetExceeded     Boolean                  @default(false)
  budgetOverrideUsed Boolean                  @default(false)
  budgetOverrideReason String?
  expenditureType    RequisitionExpenditureType @default(OPEX)
  preferredSupplier  String?
  supplierContact    String?
  supplierQuoteReference String?
  requireMultipleQuotes Boolean               @default(false)
  quotesRequired     Int?
  approvalRoute      RequisitionApprovalRoute @default(AUTO)
  manualApproverIds  Json?
  approvalRoutePreview Json?
  requestedBySnapshot Json?
  complianceChecks   Json?
  priority           Priority       @default(MEDIUM)
  status             RequisitionStatus @default(DRAFT)
  approvalRequestId  String?
  documents          Json?
  lockedAt           DateTime?
  lineItems          RequisitionLineItem[]
  attachments        RequisitionAttachment[]
  approvalSteps      RequisitionApprovalStep[]
  auditLogs          RequisitionAuditLog[]
  requestedBy        User           @relation(fields: [requestedById], references: [id])
  department         Department?    @relation(fields: [departmentId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  @@index([departmentId, status])
  @@index([requestedById, status])
  @@index([requestCategory])
  @@index([requiredByDate])
  @@index([budgetExceeded])
}

model RequisitionLineItem {
