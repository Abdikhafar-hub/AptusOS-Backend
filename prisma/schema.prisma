  blockedForCredit                   Boolean            @default(false)
  preferredDeliverySchedule          String?
  preferredOrderChannel              String?
  customerCategory                   CustomerCategory?
  accountTier                        AccountTier?
  isKeyAccount                       Boolean            @default(false)
  accountOwnerId                     String?
  territoryId                        String?
