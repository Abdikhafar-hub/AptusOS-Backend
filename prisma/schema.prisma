model LogisticsTask {
  id                        String                @id @default(cuid())
  title                     String
  description               String?
  taskType                  LogisticsTaskType
  status                    LogisticsTaskStatus   @default(PENDING)
  shipmentReferenceId       String?
  trackingNumber            String?
  originLocation            String?
  destinationLocation       String?
  transportMode             LogisticsTransportMode?
  carrierProvider           String?
  estimatedArrivalDate      DateTime?
  actualArrivalDate         DateTime?
  responsibleDepartmentId   String
  primaryAssigneeId         String?
  supervisorId              String?
  externalPartner           String?
  assignedTeamSnapshot      Json?
  startDate                 DateTime?
  expectedCompletionDate    DateTime?
  actualCompletionDate      DateTime?
  dependsOnTaskId           String?
  blockedByType             LogisticsDependencyBlockerType?
  blockedByNotes            String?
  riskLevel                 LogisticsRiskLevel    @default(MEDIUM)
  delayReason               String?
  incidentReport            String?
  alertDelayHours           Int?
  alertTemperatureBreach    Boolean               @default(false)
  alertMissedMilestone      Boolean               @default(false)
  requiredTemperatureMin    Decimal?
  requiredTemperatureMax    Decimal?
  currentTemperature        Decimal?
  monitoringDeviceId        String?
  outOfRangeAlert           Boolean               @default(false)
  createdById               String
  department                Department            @relation(fields: [responsibleDepartmentId], references: [id])
  createdBy                 User                  @relation("LogisticsTaskCreator", fields: [createdById], references: [id])
  primaryAssignee           User?                 @relation("LogisticsTaskPrimaryAssignee", fields: [primaryAssigneeId], references: [id])
  supervisor                User?                 @relation("LogisticsTaskSupervisor", fields: [supervisorId], references: [id])
  dependsOnTask             LogisticsTask?        @relation("LogisticsTaskDependencyLink", fields: [dependsOnTaskId], references: [id])
  dependentTasks            LogisticsTask[]       @relation("LogisticsTaskDependencyLink")
  items                     LogisticsTaskItem[]
  documents                 LogisticsTaskDocument[]
  milestones                LogisticsTaskMilestone[]
  dependencies              LogisticsTaskDependency[]
  dependencyReferences      LogisticsTaskDependency[] @relation("LogisticsTaskDependencyTask")
  teamMembers               LogisticsTaskTeamMember[]
  auditLogs                 LogisticsTaskAuditLog[]
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  deletedAt                 DateTime?
  @@index([responsibleDepartmentId, status])
  @@index([primaryAssigneeId, status])
  @@index([taskType, status])
  @@index([shipmentReferenceId])
  @@index([trackingNumber])
}

model LogisticsTaskItem {
