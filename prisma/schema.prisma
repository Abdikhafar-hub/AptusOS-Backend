model Delegation {
  id               String           @id @default(cuid())
  delegatorId      String
  delegateUserId   String
  modules          String[]
  restrictedModules String[]        @default([])
  restrictedDepartmentId String?
  maxApprovalAmount Decimal?
  allowFinancialApprovals Boolean   @default(false)
  allowContractApprovals Boolean    @default(false)
  immediateActivation Boolean       @default(false)
  autoExpire       Boolean          @default(true)
  reason           String?
  justification    String?
  approvalRequired Boolean          @default(false)
  approverId       String?
  approvedById     String?
  approvedAt       DateTime?
  metadata         Json?
  startAt          DateTime
  endAt            DateTime
  status           DelegationStatus @default(DRAFT)
  notes            String?
  revokedReason    String?
  resolvedAt       DateTime?
  resolvedById     String?
