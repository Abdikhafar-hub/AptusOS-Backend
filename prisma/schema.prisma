  nextFollowUpDate                   DateTime?
  customerHealthStatus               CustomerHealthStatus?
  purchaseAuthorizationRequired      Boolean            @default(false)
  status                             CustomerStatus     @default(DRAFT)
  assignedOfficerId                  String?
  notes                              String?
  rejectionReason                    String?
