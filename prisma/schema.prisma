  DOCUMENT_REJECTED
  APPROVAL_CREATED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  TASK_CREATED
  TASK_UPDATED
  LEAVE_REQUESTED
  LEAVE_APPROVED
  LEAVE_UPDATED
  FINANCE_REQUEST_CREATED
