  contactPersonRole                  String?
  contactEmail                       String?
  contactPhone                       String?
  alternatePhone                     String?
  superintendentPharmacistName       String?
  superintendentPharmacistRegistrationNumber String?
  pharmacistPhone                    String?
  pharmacistEmail                    String?
  county                             String?
  town                               String?
  physicalAddress                    String?
  buildingName                       String?
  street                             String?
  gpsLocation                        String?
  deliveryAddress                    String?
  location                           String?
  address                            String?
