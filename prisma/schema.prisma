enum SettingScopeType {
  ORGANIZATION
  DEPARTMENT
  ROLE
  USER
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  @@unique([name, deletedAt])
  @@index([name])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())
  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model User {
  id                     String                     @id @default(cuid())
  firstName              String
  lastName               String
  fullName               String
  email                  String                     @unique
  phone                  String?
  alternatePhone         String?
  gender                 Gender?
  dateOfBirth            DateTime?
  nationalId             String?
  passport               String?
  kraPin                 String?
  address                String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  jobTitle               String?
  employmentType         EmploymentType            @default(FULL_TIME)
  employmentStatus       EmploymentStatus          @default(ACTIVE)
  joinDate               DateTime?
  departmentId           String?
  managerId              String?
  roleId                 String
  passwordHash           String?
  mustChangePassword     Boolean                    @default(true)
  profilePhotoUrl        String?
  notes                  String?
  isActive               Boolean                    @default(true)
  lastLoginAt            DateTime?
  department             Department?                @relation("UserDepartment", fields: [departmentId], references: [id])
  manager                User?                      @relation("Manager", fields: [managerId], references: [id])
  directReports          User[]                     @relation("Manager")
  role                   Role                       @relation(fields: [roleId], references: [id])
  headedDepartments      Department[]               @relation("DepartmentHead")
  departmentMemberships  DepartmentMember[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  documentsUploaded      Document[]                 @relation("UploadedDocuments")
  documentsApproved      Document[]                 @relation("ApprovedDocuments")
  requestedApprovals     ApprovalRequest[]          @relation("RequestedApprovals")
  currentApprovals       ApprovalRequest[]          @relation("CurrentApprover")
  assignedTasks          Task[]                     @relation("AssignedTasks")
  createdTasks           Task[]                     @relation("CreatedTasks")
  comments               Comment[]
  notifications          Notification[]
  conversations          ConversationParticipant[]
  messages               Message[]
  channelMembers         ChannelMember[]
  channelMessages        ChannelMessage[]
  announcements          Announcement[]
  announcementReads      AnnouncementRead[]
  leaveRequests          LeaveRequest[]
  leaveBalances          LeaveBalance[]
  attendanceRecords      AttendanceRecord[]
  onboardingChecklists   OnboardingChecklist[]
  hrActions              HRAction[]                 @relation("EmployeeHRActions")
  separations            Separation[]
  remunerations          Remuneration[]
  payslips               Payslip[]                  @relation("EmployeePayslips")
  generatedPayslips      Payslip[]                  @relation("GeneratedPayslips")
  financeRequests        FinanceRequest[]
  customerOnboardings    CustomerOnboarding[]
  ownedCustomerAccounts  CustomerOnboarding[]        @relation("CustomerAccountOwner")
  assignedTerritories    SalesTerritory[]            @relation("TerritoryOfficer")
  visitRoutes            VisitRoute[]                @relation("VisitRouteOfficer")
  customerAccountNotes   CustomerAccountNote[]       @relation("CustomerAccountNoteAuthor")
  salesOpportunitiesOwned SalesOpportunity[]         @relation("SalesOpportunityOwner")
  productFeedbackSubmitted ProductFeedback[]         @relation("ProductFeedbackSubmitter")
  customerIssuesReported CustomerIssue[]             @relation("CustomerIssueReporter")
  customerIssuesAssigned CustomerIssue[]             @relation("CustomerIssueAssignee")
  discountRequestsRequested DiscountRequest[]        @relation("DiscountRequestRequester")
  salesReports           SalesReport[]
  clientVisitNotes       ClientVisitNote[]
  complaintEscalations   ComplaintEscalation[]
  complianceItems        ComplianceItem[]
  riskRegisters          RiskRegister[]
  incidentReports        IncidentReport[]
  policyAcknowledgements PolicyAcknowledgement[]
  requisitions           Requisition[]
  trainings              Training[]                 @relation("TrainingCreator")
  trainingParticipants   TrainingParticipant[]
  performanceReviews     PerformanceReview[]        @relation("EmployeeReviews")
  reviewsGiven           PerformanceReview[]        @relation("ReviewerReviews")
  auditLogs              AuditLog[]
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  deletedAt              DateTime?
  @@index([roleId])
  @@index([departmentId])
  @@index([managerId])
  @@index([employmentStatus])
}

model Department {
  id             String             @id @default(cuid())
  name           String             @unique
  slug           String             @unique
  description    String?
  headId         String?
  status         DepartmentStatus   @default(ACTIVE)
  head           User?              @relation("DepartmentHead", fields: [headId], references: [id])
  staff          User[]             @relation("UserDepartment")
  members        DepartmentMember[]
  documents      Document[]
  channels       Channel[]
  announcements  Announcement[]
  tasks          Task[]
  leavePolicies  LeavePolicy[]
  financeRequests FinanceRequest[]
  budgets        Budget[]
  requisitions   Requisition[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  @@index([headId])
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  userId       String
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@unique([departmentId, userId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@index([userId])
}

model Document {
  id                 String            @id @default(cuid())
  title              String
  description        String?
  category           DocumentCategory
  documentType       String?
  fileUrl            String
  cloudinaryPublicId String?
  fileName           String
  mimeType           String
  fileSize           Int
  ownerType          DocumentOwnerType
  ownerId            String?
  uploadedById       String
  departmentId       String?
  visibility         Visibility        @default(PRIVATE)
  status             DocumentStatus    @default(DRAFT)
  version            Int               @default(1)
  parentDocumentId   String?
  expiryDate         DateTime?
  reminderDate       DateTime?
  approvedById       String?
  approvedAt         DateTime?
  rejectionReason    String?
  uploadedBy         User              @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  approvedBy         User?             @relation("ApprovedDocuments", fields: [approvedById], references: [id])
  department         Department?       @relation(fields: [departmentId], references: [id])
  parentDocument     Document?         @relation("DocumentVersions", fields: [parentDocumentId], references: [id])
  versions           Document[]        @relation("DocumentVersions")
  documentVersions   DocumentVersion[]
  comments           Comment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  @@index([category])
  @@index([ownerType, ownerId])
  @@index([departmentId])
  @@index([status])
  @@index([expiryDate])
}

model DocumentVersion {
  id                 String   @id @default(cuid())
  documentId         String
  version            Int
  fileUrl            String
  cloudinaryPublicId String?
  fileName           String
  mimeType           String
  fileSize           Int
  uploadedById       String
  document           Document @relation(fields: [documentId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@unique([documentId, version])
}

model ApprovalRequest {
  id                String          @id @default(cuid())
  requestType       String
  entityType        String
  entityId          String
  requestedById     String
  currentApproverId String?
  status            ApprovalStatus  @default(PENDING)
  priority          Priority        @default(MEDIUM)
  reason            String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  requestedBy       User            @relation("RequestedApprovals", fields: [requestedById], references: [id])
  currentApprover   User?           @relation("CurrentApprover", fields: [currentApproverId], references: [id])
  steps             ApprovalStep[]
  comments          Comment[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  @@index([entityType, entityId])
  @@index([currentApproverId, status])
  @@index([requestedById])
}

model ApprovalStep {
  id                String         @id @default(cuid())
  approvalRequestId String
  stepOrder         Int
  approverRoleId    String?
  approverUserId    String?
  status            ApprovalStatus @default(PENDING)
  comment           String?
  actedAt           DateTime?
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  @@index([approvalRequestId, stepOrder])
}

model Task {
  id                String       @id @default(cuid())
  title             String
  description       String?
  assignedToId      String?
  assignedById      String
  departmentId      String?
  priority          Priority     @default(MEDIUM)
  status            TaskStatus   @default(TODO)
  dueDate           DateTime?
  completedAt       DateTime?
  requiresApproval  Boolean      @default(false)
  approvalRequestId String?
  recurringRule     Json?
  parentTaskId      String?
  customerId        String?
  opportunityId     String?
  issueId           String?
  visitId           String?
  assignedTo        User?        @relation("AssignedTasks", fields: [assignedToId], references: [id])
  assignedBy        User         @relation("CreatedTasks", fields: [assignedById], references: [id])
  department        Department?  @relation(fields: [departmentId], references: [id])
  parentTask        Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks          Task[]       @relation("SubTasks")
  customer          CustomerOnboarding? @relation(fields: [customerId], references: [id])
  opportunity       SalesOpportunity?   @relation(fields: [opportunityId], references: [id])
  issue             CustomerIssue?      @relation(fields: [issueId], references: [id])
  visit             ClientVisitNote?    @relation(fields: [visitId], references: [id])
  attachments       TaskAttachment[]
  comments          Comment[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  @@index([assignedToId, status])
  @@index([departmentId, status])
  @@index([dueDate])
  @@index([customerId])
  @@index([opportunityId])
  @@index([issueId])
  @@index([visitId])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  documentId String
  task       Task     @relation(fields: [taskId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([taskId])
}

model Comment {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  authorId    String
  body        String
  attachments Json?
  mentions    Json?
  author      User     @relation(fields: [authorId], references: [id])
  document    Document? @relation(fields: [documentId], references: [id])
  documentId  String?
  task        Task?    @relation(fields: [taskId], references: [id])
  taskId      String?
  approval    ApprovalRequest? @relation(fields: [approvalId], references: [id])
  approvalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  @@index([entityType, entityId])
  @@index([authorId])
}

model Conversation {
  id           String                    @id @default(cuid())
  subject      String?
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachments    Json?
  seenAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  @@index([conversationId])
  @@index([senderId])
}

model Channel {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  departmentId String?
  isCompany    Boolean          @default(false)
  department   Department?      @relation(fields: [departmentId], references: [id])
  members      ChannelMember[]
  messages     ChannelMessage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  @@index([departmentId])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  lastReadAt DateTime?
  channel   Channel  @relation(fields: [channelId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id          String   @id @default(cuid())
  channelId   String
  senderId    String
  body        String
  attachments Json?
  mentions    Json?
  pinnedAt    DateTime?
  channel     Channel  @relation(fields: [channelId], references: [id])
  sender      User     @relation(fields: [senderId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  @@index([channelId])
  @@index([senderId])
}

model Announcement {
  id              String               @id @default(cuid())
  title           String
  body            String
  priority        AnnouncementPriority @default(NORMAL)
  departmentId    String?
  publishedById   String
  expiresAt       DateTime?
  emailNotification Boolean            @default(false)
  department      Department?          @relation(fields: [departmentId], references: [id])
  publishedBy     User                 @relation(fields: [publishedById], references: [id])
  reads           AnnouncementRead[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  @@index([departmentId])
  @@index([priority])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([announcementId, userId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
