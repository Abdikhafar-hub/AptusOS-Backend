}

model ClientVisitNote {
  id               String    @id @default(cuid())
  clientName       String
  visitDate        DateTime
  notes            String
  followUpAt       DateTime?
  purpose          String?
  outcome          String?
  nextAction       String?
  nextFollowUpDate DateTime?
